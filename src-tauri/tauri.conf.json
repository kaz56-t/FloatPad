{
  "productName": "FloatPad",
  "version": "1.0.0",
  "identifier": "com.floatpad.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npx vite --config vite.config.tauri.ts",
    "beforeBuildCommand": "npx vite build --config vite.config.tauri.ts"
  },
  "app": {
    "windows": [
      {
        "title": "FloatPad",
        "width": 420,
        "height": 560,
        "minWidth": 320,
        "minHeight": 400,
        "alwaysOnTop": true,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../resources/icon.ico",
      "../resources/icon.icns"
    ]
  }
}
